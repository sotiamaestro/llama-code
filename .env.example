# Llama Code Environment Variables
# Copy this file to .env and customize as needed.
# DO NOT commit .env to version control.

# Ollama server URL (default: http://127.0.0.1:11434)
# LLAMA_CODE_OLLAMA_HOST=http://127.0.0.1:11434

# Default model (default: llama3.1:8b-instruct-q4_K_M)
# LLAMA_CODE_MODEL=llama3.1:8b-instruct-q4_K_M

# Context window size (default: 32768)
# LLAMA_CODE_NUM_CTX=32768

# Config file path override
# LLAMA_CODE_CONFIG=/path/to/config.toml
